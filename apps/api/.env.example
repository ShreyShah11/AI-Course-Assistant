DATABASE_URL=
#REDIS RQ WORKER --------------------------------------------------------------------------------------------------------------------------
REDIS_URL=

#PINECONE VECTOR DB -----------------------------------------------------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1     # AWS region for serverless index
PINECONE_CLOUD=aws                 # aws | gcp | azure
PINECONE_COURSE_INDEX_PREFIX=course

#GOOGLE API KEY 
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIM=1536
EMBEDDING_CONCURRENCY=10           # max concurrent Gemini embed calls (stay under QPM)
GEMINI_IMAGE_SUMMARY_MODEL=gemini-2.5-flash-lite
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
GEMINI_RETRIEVAL_PLANNER_MODEL=gemini-2.5-flash
GEMINI_RETRIEVAL_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_ASK_RESPONSE_MODEL=gemini-2.5-flash
GEMINI_ASK_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_QUIZ_RESPONSE_MODEL=gemini-2.5-pro
GEMINI_QUIZ_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_RESPONSE_MODEL=gemini-2.5-pro
GEMINI_SUMMARY_FALLBACK_MODEL=gemini-2.5-flash
HANDWRITTEN_FLASH_MODEL=gemini-2.5-flash
HANDWRITTEN_PRO_MODEL=gemini-2.5-pro
IMAGE_GEMINI_OCR_MODEL=gemini-2.5-flash
IMAGE_GEMINI_TEXT_MODEL=gemini-2.5-flash
IMAGE_GEMINI_ENRICH_MODEL=gemini-2.5-flash
IMAGE_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
IMAGE_GEMINI_RETRIES=3
IMAGE_GEMINI_RETRY_SLEEP_SECONDS=2
IMAGE_LOW_CONFIDENCE_THRESHOLD=60
ENABLE_IMAGE_SUMMARIES=true

#AGENTIC RETRIEVAL -----------------------------------------------------------------------------------------------------------------------
RETRIEVAL_DEFAULT_TOP_K=8
RETRIEVAL_FINAL_MAX_OUTPUT_TOKENS=4096

#DOCUMENT PDF PARSING --------------------------------------------------------------------------------------------------------------------
DOCUMENT_PDF_STRATEGY=hi_res
CHUNK_OVERLAP=200                  # chars of overlap only on hard-cap text-splits
# Set to true ONLY for PDFs with important images (diagrams, charts).
# WARNING: hi_res is 10-20x slower — a 100-page PDF can take 30-60 mins on CPU.
# Requires: detectron2 or paddle installed, tesseract system dep.
# Only effective when ENABLE_IMAGE_SUMMARIES=true.
PDF_USE_HI_RES_FOR_IMAGES=false

#NAMESPACE --------------------------------------------------------------------------------------------------------------------------
IMAGE_CHUNKING_NAMESPACE=image-chunks
DOCUMENT_CHUNKING_NAMESPACE=document-chunks
QNA_CHUNKING_NAMESPACE=qna-chunks
AUDIO_CHUNKING_NAMESPACE=audio-chunks
YOUTUBE_CHUNKING_NAMESPACE=youtube-chunks
HANDWRITTEN_CHUNKING_NAMESPACE=handwritten-chunks
AUDIO_CHUNKING_QUEUE=audio-chunking

GEMINI_RETRIEVAL_PLANNER_MODEL=gemini-2.5-flash
RETRIEVAL_DEFAULT_TOP_K=8

GEMINI_FINAL_RESPONSE_MODEL=gemini-2.5-flash
RETRIEVAL_FINAL_MAX_OUTPUT_TOKENS=4096

GEMINI_ASK_RESPONSE_MODEL=gemini-2.5-flash
GEMINI_QUIZ_RESPONSE_MODEL=gemini-2.5-pro
GEMINI_SUMMARY_RESPONSE_MODEL=gemini-2.5-pro
GEMINI_RETRIEVAL_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_ASK_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_QUIZ_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_FALLBACK_MODEL=gemini-2.5-flash

# EVAL PIPELINE (local use only) -----------------------------------------------
# Model used by the LLM-as-judge in POST /internal/evals/run
# Reuses GEMINI_API_KEY — no new API key needed.
# Leave empty to disable LLM judge and use heuristics only.
EVAL_LLM_JUDGE_MODEL=gemini-2.5-flash

RETRIEVAL_CACHE_ENABLED=true          # default: true
RETRIEVAL_CACHE_TTL_SECONDS=86400     # default: 24 hours (how long a cached query lives)
RETRIEVAL_CACHE_HIT_THRESHOLD=0.90    # default: 0.90 (cosine similarity to count as a cache hit)
RETRIEVAL_CACHE_MAX_ENTRIES=200       # per (course_id, mode) bucket; oldest entry evicted beyond this

# RATE LIMITING (token-based) ------------------------------------------------
# Limits are measured in ACTUAL GEMINI TOKENS (input + output combined),
# taken directly from response.usage_metadata.total_token_count after each call.
#
# Typical token costs per request type (rough estimates):
#   /ask        : 3,000 – 8,000  tokens  (context + planner + final response)
#   /quiz       : 6,000 – 15,000 tokens  (larger output from gemini-2.5-pro)
#   /summarize  : 6,000 – 15,000 tokens  (larger output from gemini-2.5-pro)
#
# Two-phase flow:
#   1. Pre-flight check: reject BEFORE calling Gemini if budget is already exhausted
#   2. Post-call record: write exact token count to Redis after Gemini responds
#
# Master switch — set to false to disable all rate limiting (dev/testing only)
RATE_LIMIT_ENABLED=true

# ── Tier 1: Sliding Window ────────────────────────────────────────────────────
# Max total tokens that can be consumed in any rolling 60-second window.
# No boundary spike: uses a true sliding window (Redis sorted set).
#
# Student defaults: ~50,000 tokens/min ≈ 6–15 typical requests/min
# Teacher defaults: ~150,000 tokens/min ≈ 10–50 typical requests/min
RATE_LIMIT_STUDENT_TOKENS_PER_MIN=50000
RATE_LIMIT_TEACHER_TOKENS_PER_MIN=150000

# ── Tier 2: Token Bucket ──────────────────────────────────────────────────────
# Smooths bursty traffic. Bucket capacity = max tokens that can be consumed
# in an instant burst. Refill rate = tokens replenished per second.
#
# BUCKET_CAPACITY: a student can burst up to ~10 heavy requests back-to-back
#   before the bucket drains (80,000 ÷ ~8,000 per ask ≈ 10 requests).
# BUCKET_REFILL: 800 tokens/sec = 48,000 tokens/min (below window limit,
#   so the window is the binding sustained constraint, bucket handles bursts).
RATE_LIMIT_STUDENT_BUCKET_CAPACITY=80000
RATE_LIMIT_TEACHER_BUCKET_CAPACITY=250000
RATE_LIMIT_STUDENT_BUCKET_REFILL=800.0
RATE_LIMIT_TEACHER_BUCKET_REFILL=2500.0

# ── Tier 3: Daily Quota ───────────────────────────────────────────────────────
# Absolute ceiling on total tokens per UTC calendar day (resets at midnight UTC).
# Protects against sustained slow-drain that stays within per-minute limits.
#
# Student: 500,000 tokens/day ≈ 60–160 typical requests/day
# Teacher: 2,000,000 tokens/day
RATE_LIMIT_STUDENT_TOKENS_DAILY=500000
RATE_LIMIT_TEACHER_TOKENS_DAILY=2000000

